# Copy to .env and fill in. .env is gitignored.

# `dev` caps the equity-symbol universe at 5 so the partition grid stays small.
# Anything else (or unset) = full NSE/EQ universe.
ENV=dev

# Shared trading-system Postgres. Dagster reads instruments table only.
DATABASE_URL=postgresql://<user>:<password>@localhost:5432/<database>
# Kite Connect credentials. access_token rotates daily via Zerodha OAuth.
KITE_API_KEY=
KITE_ACCESS_TOKEN=

# Root directory for CsvSource (pre-downloaded CSVs). Optional — defaults
# to "CustomSource" (relative to the Dagster working directory).
CSV_ROOT_DIR=CustomSource
